    "offers": [
        {
            "id": "offer-support",
            "number": "01",
            "title": "Дополнительная спонсорская поддержка для роддома.",
            "description": "Заведующие, врачи часто жалуются вам на нехватку того или иного, например лекарств или канцтоваров, просят сделать ремонт или купить холодильник в ординаторскую. Наша компания поддержит вас в трудную минуту."
        },
        {
            "id": "offer-mood",
            "number": "02",
            "title": "Праздничное настроение для пациентов на выписке.",
            "description": "Фотограф на выписке выступает как ведущий, ведь благодаря ему родственники вовремя будут аплодировать мамочке, дарить цветы, объятия. Выписка проходит быстро, чётко и организованно. Персонал доволен, пациенты счастливы."
        },
        {
            "id": "offer-image",
            "number": "03",
            "title": "Имидж роддома.",
            "description": "Ваш роддом будет славиться не только качественным оказанием медицинских услуг, весь город будет обсуждать в интернете, как всё продумано в вашем учреждении, от самих родов до торжественной части выписки. Рейтинг вашего учреждения будет только расти."
        },
        {
            "id": "offer-events",
            "number": "04",
            "title": "Бесплатный фотограф на все ваши мероприятия.",
            "description": "Все современные руководители уже давно завели страницы в соцсетях, делятся информацией о жизни роддома. И эти странички надо чем-то заполнять. Фото с телефона выкладывать уже не солидно. Наши фотографы обеспечат вам контент высокого уровня."
        },
        {
            "id": "offer-design",
            "number": "05",
            "title": "Услуги дизайнеров.",
            "description": "Оформление листовок, визиток, бейджей, постов в интернете и т.д. с учётом вашего бренда."
        }
    ],
